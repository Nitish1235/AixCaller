# Deepgram for STT (Speech-to-Text) and TTS (Text-to-Speech)
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# xAI (Grok) for LLM
XAI_API_KEY="your_xai_api_key_here"

# Plivo credentials (for auto-hangup and incoming call handling)
PLIVO_AUTH_ID="your_plivo_auth_id_here"
PLIVO_AUTH_TOKEN="your_plivo_auth_token_here"

# Public hostname for the WebSocket URL in Plivo XML
# Use your ngrok URL during development (without https://)
# e.g. SERVER_HOST="abc123.ngrok.io"
SERVER_HOST="your-server-host.com"
