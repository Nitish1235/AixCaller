# ==============================================================
# AIxCaller Unified Environment Variables (Production)
# ==============================================================

# --------------------------------------------------------------
# 1. Database Configurations (Supabase)
# --------------------------------------------------------------
# ⚠️  IMPORTANT: Two separate URLs are needed for Supabase.
#
# RUNTIME URL — Supabase Transaction Pooler (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# MIGRATION URL — Supabase Direct Connection (port 5432)
DATABASE_DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# --------------------------------------------------------------
# 2. External API Keys (Backend & Voice Engine)
# --------------------------------------------------------------
# OpenAI API Key — used for text-embedding-3-small (pgvector KB embeddings)
OPENAI_API_KEY="your_openai_api_key_here"

# Deepgram for STT (Speech-to-Text) and TTS (Text-to-Speech)
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# xAI (Grok) for LLM
XAI_API_KEY="your_xai_api_key_here"

# --------------------------------------------------------------
# 3. Plivo Integration (Backend)
# --------------------------------------------------------------
# Plivo credentials for auto-hangup and incoming call handling
PLIVO_AUTH_ID="your_plivo_auth_id_here"
PLIVO_AUTH_TOKEN="your_plivo_auth_token_here"

# --------------------------------------------------------------
# 4. Service URLs & Security
# --------------------------------------------------------------
# Public hostname for the WebSocket URL in Plivo XML (Backend)
# E.g., your-backend-service-url.a.run.app
SERVER_HOST="your-backend-host.com"

# Voice Engine URL (Backend -> Voice Engine routing)
# E.g., wss://your-voice-engine-service-url.a.run.app/ws
VOICE_ENGINE_URL="wss://your-voice-engine-host.com/ws"

# JWT Secret for securing Backend <-> Voice Engine communication
JWT_SECRET="your-super-secure-jwt-secret-key-change-me"

# --------------------------------------------------------------
# 5. Frontend Public Variables (Next.js)
# --------------------------------------------------------------
# URL pointing to the Backend API (e.g., https://api.aixcaller.com)
NEXT_PUBLIC_API_URL="https://your-backend-service-url.a.run.app"

# Public WebSocket URL for the Voice Engine demo (wss://)
# Used by the landing page "Talk to Agent" live demo feature
NEXT_PUBLIC_VOICE_ENGINE_WS_URL="wss://your-voice-engine-service-url.a.run.app"

# --------------------------------------------------------------
# 6. Telegram Bot Integrations
# --------------------------------------------------------------
# The secret token from Telegram's @BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
# The public username of your bot (used for the deep link)
TELEGRAM_BOT_USERNAME="AIxCaller_Alerts_Bot"
