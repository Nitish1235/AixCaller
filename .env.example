# ==============================================================================
# AIxCaller — Environment Variables Reference
# ==============================================================================
#
# Service ownership legend:
#   [B]  = backend          (f:/SAAS/AixCaller/backend)
#   [VE] = voice_engine     (f:/SAAS/AixCaller/voice_engine)
#   [FE] = frontend         (f:/SAAS/AixCaller/frontend)
#   [DB] = init_db job only (one-time migration, not a running service)
#
# Copy this file to .env and fill in every value before running locally.
# In production (Cloud Run), set these via Secret Manager / env vars per service.
# ==============================================================================


# ------------------------------------------------------------------------------
# DATABASE  [B] [VE] [DB]
# ------------------------------------------------------------------------------

# RUNTIME — Supabase Transaction Pooler (port 6543)
# Used by backend & voice_engine at runtime (Cloud Run friendly, pooled)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# MIGRATION — Supabase Direct Connection (port 5432)
# Used ONLY by the init_db one-time job (enables pgvector + creates tables)
DATABASE_DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"


# ------------------------------------------------------------------------------
# REDIS / UPSTASH  [B] [VE]
# ------------------------------------------------------------------------------
# Upstash Redis — used as L1 cache for KB results & hot-KB pre-warming.
# Sign up at https://upstash.com (free tier: 10K commands/day).
# Copy the "Redis (TLS)" connection URL — starts with rediss:// (note: two s's for TLS).
# If unset, KB cache layers are skipped and full pgvector search is used (slower but works).
REDIS_URL="rediss://default:[password]@[your-region].upstash.io:6379"


# ------------------------------------------------------------------------------
# AI / LLM  [B] [VE]
# ------------------------------------------------------------------------------

# OpenAI — used by backend for KB embeddings (text-embedding-3-small, 1536 dims)
# Also used by backend/services/analytics.py for call summarisation via xAI
OPENAI_API_KEY="your_openai_api_key_here"

# xAI (Grok) — LLM for live voice conversations and call analytics
# Used by: voice_engine/bot.py, voice_engine/demo_session.py, backend/services/analytics.py
XAI_API_KEY="your_xai_api_key_here"


# ------------------------------------------------------------------------------
# 5. TELEPHONY CONFIG (TELNYX)
# ------------------------------------------------------------------------------
TELNYX_API_KEY="KEY0123456789"
# The connection ID of your Telnyx TeXML application (for outbound dialing)
TELNYX_CONNECTION_ID="1234567890"

# Deepgram STT (Speech-to-Text) + TTS (Text-to-Speech)
# Used by: voice_engine/bot.py, voice_engine/demo_session.py, backend/api/admin.py
DEEPGRAM_API_KEY="your_deepgram_api_key_here"


# ------------------------------------------------------------------------------
# SHOPIFY OAuth INTEGRATION  [B]
# ------------------------------------------------------------------------------
# Create a public app in the Shopify Partner Dashboard:
#   https://partners.shopify.com → Apps → Create app → "Public app"
# Set the App URL to your dashboard, and "Allowed redirection URL(s)" to:
#   https://<your-backend>/api/v1/shopify/callback
# Then copy the Client ID and Client Secret here.
SHOPIFY_API_KEY="your_shopify_app_client_id"
SHOPIFY_API_SECRET="your_shopify_app_client_secret"
# Scopes the app requests on install. Keep to read-only for least privilege.
SHOPIFY_SCOPES="read_orders,read_customers,read_products,read_inventory,read_fulfillments"
# MUST exactly match a "Allowed redirection URL" in the Partner Dashboard.
SHOPIFY_REDIRECT_URI="https://backend-597874469660.europe-west1.run.app/api/v1/shopify/callback"


# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------

# Plivo credentials — inbound call routing, outbound recovery dialer
# Used by: backend/main.py, backend/services/outbound_dialer.py, voice_engine/bot.py
PLIVO_AUTH_ID="your_plivo_auth_id_here"
PLIVO_AUTH_TOKEN="your_plivo_auth_token_here"


# ------------------------------------------------------------------------------
# SERVICE URLs & SECURITY  [B] [VE]
# ------------------------------------------------------------------------------

# JWT shared secret — signs call tokens passed from backend → voice_engine
# Used by: backend/main.py (sign), voice_engine/main.py (verify)
JWT_SECRET="your-super-secure-jwt-secret-min-32-chars"

# Backend public hostname WITHOUT https:// (used to build outbound answer URL)
# Used by: backend/services/outbound_dialer.py
# Example: aixcaller-backend-xxxx.a.run.app
SERVER_HOST="your-backend-host.a.run.app"

# Voice Engine WebSocket URL — wss:// address voice_engine is reachable at
# Used by: backend/main.py to embed in Plivo XML Connect
# Example: wss://aixcaller-voice-engine-xxxx.a.run.app/ws
VOICE_ENGINE_URL="wss://your-voice-engine-host.a.run.app/ws"

# Backend HTTPS URL — voice_engine calls backend to fetch KB context
# Used by: voice_engine/bot.py
# Example: https://aixcaller-backend-xxxx.a.run.app
BACKEND_URL="https://your-backend-host.a.run.app"


# ------------------------------------------------------------------------------
# PAYMENTS — DodoPayments  [B]
# ------------------------------------------------------------------------------

# Dodo Payments API key and environment
# Used by: backend/services/payments.py
DODO_PAYMENTS_API_KEY="your_dodo_payments_api_key_here"
# Options: "test_mode" | "live_mode"
DODO_PAYMENTS_ENVIRONMENT="test_mode"

# URL users are redirected to after completing a payment
# Used by: backend/services/payments.py
# Example: https://aixcaller-frontend-xxxx.a.run.app/dashboard
DASHBOARD_URL="https://your-frontend-host.a.run.app/dashboard"


# ------------------------------------------------------------------------------
# GOOGLE CLOUD STORAGE  [B]
# ------------------------------------------------------------------------------

# GCS bucket for voice preview audio files and other assets
# Used by: backend/api/admin.py
GCS_BUCKET_NAME="aixcaller-assets"


# ------------------------------------------------------------------------------
# TELEGRAM BOT  [B]
# ------------------------------------------------------------------------------

# Token from @BotFather — backend registers the webhook and sends alerts
# Used by: backend/api/telegram.py
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Public username of your Telegram bot (without @), used for deep links in UI
# Used by: frontend/src/app/dashboard/integrations/page.tsx
TELEGRAM_BOT_USERNAME="AIxCaller_Alerts_Bot"


# ------------------------------------------------------------------------------
# FRONTEND — Next.js Public Variables  [FE]
# ------------------------------------------------------------------------------
# All NEXT_PUBLIC_* vars are embedded into the client bundle at build time.
# They MUST be set before running `npm run build`.

# Backend API base URL — all dashboard API calls go here
# Used by: frontend/src/lib/api.ts
NEXT_PUBLIC_API_URL="https://your-backend-host.a.run.app"

# Voice Engine WebSocket base URL — landing page demo + live dashboard
# Used by: frontend/src/app/page.tsx (/demo endpoint)
#          frontend/src/app/dashboard/live/page.tsx
NEXT_PUBLIC_VOICE_ENGINE_WS_URL="wss://your-voice-engine-host.a.run.app"

# Backend WebSocket URL for the live dashboard call monitor
# Used by: frontend/src/app/dashboard/live/page.tsx
NEXT_PUBLIC_WS_URL="wss://your-backend-host.a.run.app/ws"

# Telegram bot username for the integration deep-link button in the dashboard
# Used by: frontend/src/app/dashboard/integrations/page.tsx
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="AIxCaller_Alerts_Bot"


# ==============================================================================
# QUICK REFERENCE — Which service needs what
# ==============================================================================
#
#  Variable                        | [B] | [VE] | [FE] | [DB]
#  --------------------------------|-----|------|------|-----
#  DATABASE_URL                    |  ✓  |  ✓   |      |  ✓
#  DATABASE_DIRECT_URL             |     |      |      |  ✓
#  OPENAI_API_KEY                  |  ✓  |      |      |
#  XAI_API_KEY                     |  ✓  |  ✓   |      |
#  DEEPGRAM_API_KEY                |  ✓  |  ✓   |      |
#  REDIS_URL                       |  ✓  |  ✓   |      |
#  TELNYX_API_KEY                  |  ✓  |  ✓   |      |
#  TELNYX_CONNECTION_ID            |  ✓  |      |      |
#  JWT_SECRET                      |  ✓  |  ✓   |      |
#  SERVER_HOST                     |  ✓  |      |      |
#  VOICE_ENGINE_URL                |  ✓  |      |      |
#  BACKEND_URL                     |     |  ✓   |      |
#  DODO_PAYMENTS_API_KEY           |  ✓  |      |      |
#  DODO_PAYMENTS_ENVIRONMENT       |  ✓  |      |      |
#  DASHBOARD_URL                   |  ✓  |      |      |
#  GCS_BUCKET_NAME                 |  ✓  |      |      |
#  TELEGRAM_BOT_TOKEN              |  ✓  |      |      |
#  TELEGRAM_BOT_USERNAME           |  ✓  |      |      |
#  NEXT_PUBLIC_API_URL             |     |      |  ✓   |
#  NEXT_PUBLIC_VOICE_ENGINE_WS_URL |     |      |  ✓   |
#  NEXT_PUBLIC_WS_URL              |     |      |  ✓   |
#  NEXT_PUBLIC_TELEGRAM_BOT_USERNAME|    |      |  ✓   |
# ==============================================================================
